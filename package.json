{
  "name": "@riddledc/integrations",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@9.15.2",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "pnpm -r build",
    "clean": "pnpm -r clean",
    "formal:build": "cd formal/riddle-proof-kernel && lake build",
    "lint": "pnpm -r lint",
    "test": "node scripts/check-openclaw-plugin-versions.mjs && pnpm -r test",
    "changeset": "changeset",
    "version-packages": "changeset version && pnpm -r --if-present sync:openclaw-plugin-version && pnpm install --lockfile-only",
    "release": "changeset publish --access public"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "tsup": "^8.0.1",
    "typescript": "^6.0.3"
  }
}
