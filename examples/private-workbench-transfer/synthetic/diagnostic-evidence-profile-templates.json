        "collector_id": "riddle-proof.synthetic-offline-collector",
        "collector_version": "1",
        "implementation_digest": "sha256:4444444444444444444444444444444444444444444444444444444444444444"
      },
      "sensor_template": {
        "kind": "other",
        "name": "synthetic-local-files",
        "version": "1",
        "metadata": {
          "network_used": false,
          "source_mutation": false,
          "synthetic": true
        },
        "observed_target_binding": "expected_scope.target"
      },
      "trusted_signer": {
        "key_id": "synthetic-offline-foundation-key",
        "public_key_spki_base64": "MCowBQYDK2VwAyEA0/Diax3hBEXiqPo6JLj41YdI+IbZniZ4FkPQbWRyej4="
      },
      "verifier_definition": {
        "verifier_id": "riddle-proof.local-document-snapshot.declarative",
        "verifier_version": "1",
        "program": {
          "artifact": {
            "artifact_id": "document-snapshot-observation.json",
            "role": "document_snapshot_observation",
            "media_type": "application/json"
          },
          "pointer": ""
        }
      },
      "observation_schema": {
        "kind": "object",
        "properties": {
          "version": { "kind": "literal", "value": "riddle.document-snapshot-observation.v1" },
          "snapshot_id": { "kind": "claim_parameter", "parameter": "snapshot_id" },
          "manifest_digest": { "kind": "claim_parameter", "parameter": "manifest_digest" },
          "artifact_policy": { "kind": "literal", "value": "digest_only" },
          "capture": {
            "kind": "object",
            "properties": {
              "method": { "kind": "literal", "value": "stable_file_descriptor_set_pre_read_post_stat.v1" },
              "stable": { "kind": "literal", "value": true },
              "source_documents_mutated": { "kind": "literal", "value": false }
            }
          },
          "artifacts": {
            "kind": "array",
            "items": [
              {
                "kind": "object",
                "properties": {
                  "role": { "kind": "literal", "value": "candidate" },
                  "media_type": { "kind": "literal", "value": "text/plain" },
                  "byte_length": { "kind": "integer", "minimum": 0, "maximum": 67108864 },
                  "digest": { "kind": "sha256" }
                }
              },
              {
                "kind": "object",
                "properties": {
                  "role": { "kind": "literal", "value": "criteria" },
                  "media_type": { "kind": "literal", "value": "text/plain" },
                  "byte_length": { "kind": "integer", "minimum": 0, "maximum": 67108864 },
                  "digest": { "kind": "sha256" }
                }
              },
              {
                "kind": "object",
                "properties": {
                  "role": { "kind": "literal", "value": "rendered" },
                  "media_type": { "kind": "literal", "value": "application/pdf" },
                  "byte_length": { "kind": "integer", "minimum": 0, "maximum": 67108864 },
                  "digest": { "kind": "sha256" }
                }
              },
              {
                "kind": "object",
                "properties": {
                  "role": { "kind": "literal", "value": "source" },
                  "media_type": { "kind": "literal", "value": "text/plain" },
                  "byte_length": { "kind": "integer", "minimum": 0, "maximum": 67108864 },
                  "digest": { "kind": "sha256" }
                }
              }
            ]
          }
        }
      },
      "contract_template": {
        "contract_id": "riddle-proof.local-document-snapshot-captured.declarative",
        "contract_version": "1",
        "label": "A stable read-only local document snapshot was captured",
        "claim": {
          "claim_id": "riddle-proof.diagnostic.snapshot-captured",
          "claim_version": "1",
          "label": "Selected local document bytes were captured without source mutation"
        },
        "required_assertions": [
          { "op": "equals", "source": "observation", "pointer": "/version", "value": "riddle.document-snapshot-observation.v1" },
          { "op": "equals", "source": "observation", "pointer": "/capture/method", "value": "stable_file_descriptor_set_pre_read_post_stat.v1" },
          { "op": "equals", "source": "observation", "pointer": "/capture/stable", "value": true },
          { "op": "equals", "source": "observation", "pointer": "/capture/source_documents_mutated", "value": false },
          { "op": "type_is", "source": "observation", "pointer": "/artifacts", "type": "array" }
        ],
        "parameter_bindings": [
          { "parameter": "snapshot_id", "observation_pointers": ["/snapshot_id"], "allowed_json_types": ["string"] },
          { "parameter": "manifest_digest", "observation_pointers": ["/manifest_digest"], "allowed_json_types": ["string"] }
        ]
      },
      "required_artifact_roles": ["document_snapshot_observation"]
    },
