        "required_assertions": [
          { "op": "equals", "source": "observation", "pointer": "/version", "value": "riddle-proof.synthetic-required-artifact-roles.v1" },
          { "op": "equals", "source": "observation", "pointer": "/required_roles", "value": ["candidate", "criteria", "rendered", "source"] },
          { "op": "equals", "source": "observation", "pointer": "/observed_roles", "value": ["candidate", "criteria", "rendered", "source"] },
          { "op": "equals", "source": "observation", "pointer": "/status", "value": "complete" }
        ],
        "parameter_bindings": [
          { "parameter": "snapshot_id", "observation_pointers": ["/snapshot_id"], "allowed_json_types": ["string"] },
          { "parameter": "manifest_digest", "observation_pointers": ["/manifest_digest"], "allowed_json_types": ["string"] }
