{
  "schema": "riddle.runner.manifest@1",
  "key": "playwright-basic-runner@1",
  "name": "playwright-basic-runner",
  "version": "1.0.0",
  "entry": "bin/index.mjs",
  "task_types": ["playwright_basic"],
  "env": {
    "SCREENSHOT_DIR": "screenshots"
  },
  "capabilities": {
    "playwright_basic": {
      "actions": ["screenshot"],
      "formats": ["png", "webp"],
      "timeout_sec": 120
    }
  },
  "resource_requirements": {
    "cpu_cores": 1,
    "mem_gb": 2,
    "timeout_sec": 180
  },
  "platform": {
    "os": "linux",
    "arch": "x64"
  }
}
