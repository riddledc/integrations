#!/usr/bin/env node
import {
  runLocalProofGuidedCtaChange,
} from "../dist/cta-main.js";

let running;

async function close() {
  if (!running) return;
  const current = running;
  running = null;
  await current.close();
}

try {
  running = await runLocalProofGuidedCtaChange();
  if (running) {
    process.once("SIGINT", () => {
      void close().finally(() => {
        process.exitCode = 130;
      });
    });
    process.once("SIGTERM", () => {
      void close().finally(() => {
        process.exitCode = 143;
      });
    });
  }
} catch (error) {
  process.stderr.write(
    `${error instanceof Error ? error.message : String(error)}\n`,
  );
  process.exitCode = 1;
}
