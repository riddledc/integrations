{
  "name": "@riddledc/riddle-proof",
  "version": "0.7.35",
  "description": "Reusable Riddle Proof contracts and helpers for evidence-backed agent changes.",
  "license": "MIT",
  "author": "RiddleDC",
  "repository": {
    "type": "git",
    "url": "https://github.com/riddledc/integrations",
    "directory": "packages/riddle-proof"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js",
      "require": "./dist/types.cjs"
    },
    "./result": {
      "types": "./dist/result.d.ts",
      "import": "./dist/result.js",
      "require": "./dist/result.cjs"
    },
    "./state": {
      "types": "./dist/state.d.ts",
      "import": "./dist/state.js",
      "require": "./dist/state.cjs"
    },
    "./checkpoint": {
      "types": "./dist/checkpoint.d.ts",
      "import": "./dist/checkpoint.js",
      "require": "./dist/checkpoint.cjs"
    },
    "./run-card": {
      "types": "./dist/run-card.d.ts",
      "import": "./dist/run-card.js",
      "require": "./dist/run-card.cjs"
    },
    "./runner": {
      "types": "./dist/runner.d.ts",
      "import": "./dist/runner.js",
      "require": "./dist/runner.cjs"
    },
    "./engine-harness": {
      "types": "./dist/engine-harness.d.ts",
      "import": "./dist/engine-harness.js",
      "require": "./dist/engine-harness.cjs"
    },
    "./codex-exec-agent": {
      "types": "./dist/codex-exec-agent.d.ts",
      "import": "./dist/codex-exec-agent.js",
      "require": "./dist/codex-exec-agent.cjs"
    },
    "./local-agent": {
      "types": "./dist/local-agent.d.ts",
      "import": "./dist/local-agent.js",
      "require": "./dist/local-agent.cjs"
    },
    "./diagnostics": {
      "types": "./dist/diagnostics.d.ts",
      "import": "./dist/diagnostics.js",
      "require": "./dist/diagnostics.cjs"
    },
    "./proof-session": {
      "types": "./dist/proof-session.d.ts",
      "import": "./dist/proof-session.js",
      "require": "./dist/proof-session.cjs"
    },
    "./playability": {
      "types": "./dist/playability.d.ts",
      "import": "./dist/playability.js",
      "require": "./dist/playability.cjs"
    },
    "./basic-gameplay": {
      "types": "./dist/basic-gameplay.d.ts",
      "import": "./dist/basic-gameplay.js",
      "require": "./dist/basic-gameplay.cjs"
    },
    "./profile": {
      "types": "./dist/profile.d.ts",
      "import": "./dist/profile.js",
      "require": "./dist/profile.cjs"
    },
    "./openclaw": {
      "types": "./dist/openclaw.d.ts",
      "import": "./dist/openclaw.js",
      "require": "./dist/openclaw.cjs"
    },
    "./proof-run-core": {
      "types": "./dist/proof-run-core.d.ts",
      "import": "./dist/proof-run-core.js",
      "require": "./dist/proof-run-core.cjs"
    },
    "./proof-run-engine": {
      "types": "./dist/proof-run-engine.d.ts",
      "import": "./dist/proof-run-engine.js",
      "require": "./dist/proof-run-engine.cjs"
    },
    "./riddle-client": {
      "types": "./dist/riddle-client.d.ts",
      "import": "./dist/riddle-client.js",
      "require": "./dist/riddle-client.cjs"
    }
  },
  "bin": {
    "riddle-proof-loop": "./dist/cli.js"
  },
  "files": [
    "dist",
    "examples",
    "lib",
    "runtime",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup src/index.ts src/types.ts src/result.ts src/state.ts src/checkpoint.ts src/run-card.ts src/runner.ts src/engine-harness.ts src/codex-exec-agent.ts src/local-agent.ts src/cli.ts src/diagnostics.ts src/proof-session.ts src/playability.ts src/basic-gameplay.ts src/profile.ts src/openclaw.ts src/proof-run-core.ts src/proof-run-engine.ts src/riddle-client.ts --format cjs,esm --dts --out-dir dist --clean",
    "clean": "rm -rf dist",
    "lint": "echo 'lint: (not configured)'",
    "test": "npm run build && node test.js && node proof-run.test.js"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.0.1",
    "typescript": "^5.4.5"
  }
}
