{
  "name": "@riddledc/riddle-worker-contract",
  "version": "0.2.0",
  "description": "Public worker/job contracts for Riddle runner interoperability.",
  "license": "MIT",
  "author": "RiddleDC",
  "repository": {
    "type": "git",
    "url": "https://github.com/riddledc/integrations",
    "directory": "packages/riddle-worker-contract"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./job-v2": {
      "types": "./dist/job-v2.d.ts",
      "import": "./dist/job-v2.js",
      "require": "./dist/job-v2.cjs"
    },
    "./runner-manifest": {
      "types": "./dist/runner-manifest.d.ts",
      "import": "./dist/runner-manifest.js",
      "require": "./dist/runner-manifest.cjs"
    },
    "./artifact": {
      "types": "./dist/artifact.d.ts",
      "import": "./dist/artifact.js",
      "require": "./dist/artifact.cjs"
    },
    "./result": {
      "types": "./dist/result.d.ts",
      "import": "./dist/result.js",
      "require": "./dist/result.cjs"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup src/index.ts src/job-v2.ts src/runner-manifest.ts src/artifact.ts src/result.ts --format cjs,esm --dts --out-dir dist --clean",
    "clean": "rm -rf dist",
    "lint": "echo 'lint: (not configured)'",
    "test": "npm run build && node test.js"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.0.1",
    "typescript": "^5.4.5"
  }
}
