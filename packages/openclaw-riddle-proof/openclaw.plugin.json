{
  "id": "openclaw-riddle-proof",
  "name": "Riddle Proof",
  "description": "OpenClaw wrapper for Riddle Proof evidence-backed agent changes.",
  "version": "0.4.0",
  "type": "plugin",
  "bundledSkills": [],
  "capabilities": {
    "network": {
      "egress": [],
      "enforced": true,
      "note": "The wrapper itself does not need network egress; configured engine or agent adapters must declare additional egress if added."
    },
    "filesystem": {
      "write": [
        "/tmp/riddle-proof-run-*.json",
        "/tmp/riddle-proof-codex-*"
      ],
      "read": [
        "/tmp/riddle-proof-run-*.json",
        "/tmp/riddle-proof-codex-*",
        "/root/.openclaw/extensions/riddle-proof-run"
      ]
    },
    "agentContext": {
      "conversationHistory": false,
      "otherToolOutputs": false,
      "userProfile": false,
      "note": "Plugin only sees data explicitly passed to its tool."
    },
    "tools": {
      "provides": [
        "riddle_proof_change",
        "riddle_proof_status"
      ],
      "invokes": [
        "codex exec"
      ],
      "note": "The wrapper calls reusable logic directly and does not invoke another OpenClaw plugin runtime. The Codex exec adapter only runs when explicitly configured."
    },
    "secrets": {
      "required": [],
      "optional": [],
      "note": "No secrets are required by the initial wrapper."
    }
  },
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "executionMode": {
        "type": "string",
        "enum": [
          "disabled",
          "engine"
        ],
        "description": "disabled returns the normalized blocked envelope; engine calls the configured local Riddle Proof engine."
      },
      "agentMode": {
        "type": "string",
        "enum": [
          "disabled",
          "codex_exec"
        ],
        "description": "disabled stops at agent checkpoints; codex_exec uses the local codex CLI as the checkpoint agent."
      },
      "riddleEngineModuleUrl": {
        "type": "string"
      },
      "riddleProofDir": {
        "type": "string"
      },
      "defaultReviewer": {
        "type": "string"
      },
      "stateDir": {
        "type": "string"
      },
      "defaultMaxIterations": {
        "type": "number"
      },
      "defaultShipMode": {
        "type": "string",
        "enum": [
          "none",
          "ship"
        ]
      },
      "codexCommand": {
        "type": "string"
      },
      "codexHome": {
        "type": "string"
      },
      "codexModel": {
        "type": "string"
      },
      "codexTimeoutMs": {
        "type": "number"
      },
      "codexSandbox": {
        "type": "string",
        "enum": [
          "read-only",
          "workspace-write",
          "danger-full-access"
        ]
      },
      "codexFullAuto": {
        "type": "boolean"
      }
    }
  }
}
