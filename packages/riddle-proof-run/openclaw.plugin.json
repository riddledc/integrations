{
  "id": "riddle-proof-run",
  "name": "Riddle Proof Run",
  "description": "Evidence-backed workflow runner for preview, recon, verify, ship, and status steps around Riddle Proof.",
  "version": "0.1.0",
  "type": "plugin",
  "entry": "./dist/index.js",
  "capabilities": {
    "filesystem": {
      "read": [
        "/tmp/riddle-proof-*.json",
        "/tmp/riddle-proof-state.json",
        "/root/.openclaw/extensions/riddle-proof-run/runtime"
      ],
      "write": [
        "/tmp/riddle-proof-*.json",
        "/tmp/riddle-proof-state.json"
      ]
    },
    "tools": {
      "provides": ["riddle_proof_run"],
      "invokes": []
    }
  },
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "riddleProofDir": { "type": "string" },
      "statePath": { "type": "string" },
      "defaultReviewer": { "type": "string" }
    }
  },
  "deployment": {
    "oc": {
      "enabled": true
    }
  }
}
