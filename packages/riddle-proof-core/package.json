{
  "name": "@riddledc/riddle-proof-core",
  "version": "0.1.0",
  "description": "Capability-bounded Riddle Proof contracts, receipts, semantic certificates, and grounded verification.",
  "license": "MIT",
  "author": "RiddleDC",
  "repository": {
    "type": "git",
    "url": "https://github.com/riddledc/integrations",
    "directory": "packages/riddle-proof-core"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./profile": {
      "types": "./dist/profile.d.ts",
      "import": "./dist/profile.js",
      "require": "./dist/profile.cjs"
    },
    "./receipts": {
      "types": "./dist/receipts.d.ts",
      "import": "./dist/receipts.js",
      "require": "./dist/receipts.cjs"
    },
    "./semantic-certificate": {
      "types": "./dist/semantic-certificate.d.ts",
      "import": "./dist/semantic-certificate.js",
      "require": "./dist/semantic-certificate.cjs"
    },
    "./grounded-evidence": {
      "types": "./dist/grounded-evidence.d.ts",
      "import": "./dist/grounded-evidence.js",
      "require": "./dist/grounded-evidence.cjs"
    },
    "./checked-meaning": {
      "types": "./dist/checked-meaning.d.ts",
      "import": "./dist/checked-meaning.js",
      "require": "./dist/checked-meaning.cjs"
    },
    "./rule-trust-root": {
      "types": "./dist/rule-trust-root.d.ts",
      "import": "./dist/rule-trust-root.js",
      "require": "./dist/rule-trust-root.cjs"
    },
    "./evidence-trust-root": {
      "types": "./dist/evidence-trust-root.d.ts",
      "import": "./dist/evidence-trust-root.js",
      "require": "./dist/evidence-trust-root.cjs"
    },
    "./packet": {
      "types": "./dist/packet.d.ts",
      "import": "./dist/packet.js",
      "require": "./dist/packet.cjs"
    },
    "./json": {
      "types": "./dist/json.d.ts",
      "import": "./dist/json.js",
      "require": "./dist/json.cjs"
    },
    "./capabilities": "./capabilities.json"
  },
  "files": [
    "dist",
    "capabilities.json",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "riddleProofCapabilities": {
    "network": false,
    "filesystem": false,
    "browser": false,
    "subprocess": false,
    "hostedRiddle": false,
    "cryptography": true,
    "ambientClock": true
  },
  "scripts": {
    "build": "tsup src/index.ts src/profile.ts src/receipts.ts src/semantic-certificate.ts src/grounded-evidence.ts src/checked-meaning.ts src/rule-trust-root.ts src/evidence-trust-root.ts src/packet.ts src/json.ts --format cjs,esm --dts --out-dir dist --clean",
    "clean": "rm -rf dist",
    "lint": "echo 'lint: (not configured)'",
    "test": "npm run build && node --require ../../scripts/deny-network.cjs test.js && node --require ../../scripts/deny-network.cjs checked-meaning.test.js && node --require ../../scripts/deny-network.cjs rule-trust-root.test.js && node --require ../../scripts/deny-network.cjs evidence-trust-root.test.js && node --require ../../scripts/deny-network.cjs packet.test.js"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.0.1",
    "typescript": "^5.4.5"
  }
}
