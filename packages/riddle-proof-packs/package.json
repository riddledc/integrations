{
  "name": "@riddledc/riddle-proof-packs",
  "version": "0.8.22",
  "description": "Reusable proof pack profiles and metadata helpers for the Riddle proof framework.",
  "license": "MIT",
  "author": "RiddleDC",
  "repository": {
    "type": "git",
    "url": "https://github.com/riddledc/integrations",
    "directory": "packages/riddle-proof-packs"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./audio-mix-heuristics": {
      "types": "./dist/audioMixHeuristics.d.ts",
      "import": "./dist/audioMixHeuristics.js",
      "require": "./dist/audioMixHeuristics.cjs"
    },
    "./audio-mix-review": {
      "types": "./dist/audioMixReview.d.ts",
      "import": "./dist/audioMixReview.js",
      "require": "./dist/audioMixReview.cjs"
    }
  },
  "files": [
    "dist",
    "packs",
    "bin",
    "LICENSE",
    "README.md"
  ],
  "bin": {
    "riddle-proof-durable-candidate-plan": "./bin/riddle-proof-durable-candidate-plan",
    "riddle-proof-review-packet": "./bin/riddle-proof-review-packet"
  },
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup src/index.ts src/audioMixHeuristics.ts src/audioMixReview.ts src/reviewPacketCli.ts src/durableCandidatePlanCli.ts --format cjs,esm --dts --out-dir dist --clean",
    "clean": "rm -rf dist",
    "lint": "echo 'lint: (not configured)'",
    "test": "npm run build && node test.js"
  },
  "dependencies": {
    "@riddledc/riddle-proof": "workspace:^"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.0.1",
    "typescript": "^5.4.5"
  }
}
