{
  "name": "@riddledc/riddle-proof-riddle-client",
  "version": "0.4.0",
  "description": "Hosted Riddle API client and job polling helpers for Proof workflows.",
  "license": "MIT",
  "author": "RiddleDC",
  "repository": {
    "type": "git",
    "url": "https://github.com/riddledc/integrations",
    "directory": "packages/riddle-proof-riddle-client"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js",
      "require": "./dist/client.cjs"
    },
    "./balance": {
      "types": "./dist/balance.d.ts",
      "import": "./dist/balance.js",
      "require": "./dist/balance.cjs"
    },
    "./preview": {
      "types": "./dist/preview.d.ts",
      "import": "./dist/preview.js",
      "require": "./dist/preview.cjs"
    },
    "./runScript": {
      "types": "./dist/runScript.d.ts",
      "import": "./dist/runScript.js",
      "require": "./dist/runScript.cjs"
    },
    "./serverPreview": {
      "types": "./dist/serverPreview.d.ts",
      "import": "./dist/serverPreview.js",
      "require": "./dist/serverPreview.cjs"
    },
    "./polling": {
      "types": "./dist/polling.d.ts",
      "import": "./dist/polling.js",
      "require": "./dist/polling.cjs"
    },
    "./artifacts": {
      "types": "./dist/artifacts.d.ts",
      "import": "./dist/artifacts.js",
      "require": "./dist/artifacts.cjs"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup src/index.ts src/client.ts src/balance.ts src/preview.ts src/runScript.ts src/serverPreview.ts src/polling.ts src/artifacts.ts --format cjs,esm --dts --out-dir dist --clean",
    "clean": "rm -rf dist",
    "lint": "echo 'lint: (not configured)'",
    "test": "npm run build && node test.js"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.0.1",
    "typescript": "^5.4.5"
  }
}
