{
  "name": "@riddledc/riddle-proof-local",
  "version": "0.0.0",
  "description": "Network-free, read-only local document snapshot capture for Riddle Proof.",
  "license": "MIT",
  "author": "RiddleDC",
  "repository": {
    "type": "git",
    "url": "https://github.com/riddledc/integrations",
    "directory": "packages/riddle-proof-local"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./capabilities": "./capabilities.json"
  },
  "files": [
    "dist",
    "bin",
    "README.md",
    "LICENSE",
    "capabilities.json"
  ],
  "bin": {
    "riddle-proof-local": "./bin/riddle-proof-local"
  },
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "riddleProofCapabilities": {
    "network": false,
    "filesystem": true,
    "browser": false,
    "subprocess": false,
    "hostedRiddle": false,
    "cryptography": true,
    "ambientClock": true
  },
  "scripts": {
    "build": "tsup src/index.ts src/cli.ts src/stableRead.ts --format cjs,esm --dts --out-dir dist --clean",
    "clean": "rm -rf dist",
    "lint": "echo 'lint: (not configured)'",
    "test": "npm run build && node test.js",
    "test:grounded": "pnpm --dir ../riddle-proof-core build && npm run build && node grounded-integration.test.js",
    "test:meaning": "pnpm --dir ../riddle-proof-core build && npm run build && node meaning-integration.test.js"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.0.1",
    "typescript": "^5.4.5"
  }
}
